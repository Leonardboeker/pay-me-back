---
import '../styles/global.css';

interface Props {
  title?: string;
  /** Per-debtor OG image path (e.g. "/og/abc123.png"). When set, link-preview
   *  apps (WhatsApp, iMessage, Twitter) render a personalised card. */
  ogImage?: string;
  /** OG description shown beneath the title in link previews */
  ogDescription?: string;
}
const {
  title = 'pay-me-back',
  ogImage,
  ogDescription = 'A friend-shaped pay-me-back microsite.',
} = Astro.props;

// Resolve OG image to a full URL so platforms that require absolute URLs work
const ogImageAbsolute = ogImage
  ? new URL(ogImage, Astro.site ?? Astro.url.origin).toString()
  : undefined;

// ───────────────────────────────────────────────────────────────
// Attribution footer
// Shown at the very bottom of every page. Lets visitors see this is
// open-source and find the template to build their own.
//
// To remove or customise: delete the <footer class="built-with-footer">
// block below. (Keeping it is appreciated, not required — MIT license.)
// ───────────────────────────────────────────────────────────────
const REPO_URL = 'https://github.com/Leonardboeker/pay-me-back';
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="referrer" content="no-referrer" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    {/* Open Graph / Twitter card — shown in WhatsApp, iMessage, Slack, Twitter etc. */}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:type" content="website" />
    {ogImageAbsolute && <meta property="og:image" content={ogImageAbsolute} />}
    {ogImageAbsolute && <meta property="og:image:width" content="1200" />}
    {ogImageAbsolute && <meta property="og:image:height" content="630" />}
    <meta name="twitter:card" content={ogImageAbsolute ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={ogDescription} />
    {ogImageAbsolute && <meta name="twitter:image" content={ogImageAbsolute} />}

    <slot name="head" />
    <style>
      /* Attribution footer — see comment in BaseLayout.astro */
      .built-with-footer {
        width: 100%;
        padding: 14px 16px;
        background: var(--color-surface-container-lowest, #f6f0e3);
        border-top: 3px solid var(--color-on-background, #2a1f1a);
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        font-family: 'JetBrains Mono', ui-monospace, monospace;
        font-size: 11px;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--color-on-surface-variant, #6b5d52);
      }
      .built-with-footer a {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        color: var(--color-on-background, #2a1f1a);
        font-weight: 700;
        text-decoration: none;
        border-bottom: 2px solid currentColor;
        padding-bottom: 1px;
        transition: color 0.15s ease;
      }
      .built-with-footer a:hover,
      .built-with-footer a:focus-visible {
        color: var(--color-primary, #c0573a);
      }
      .built-with-footer svg {
        width: 14px;
        height: 14px;
        flex-shrink: 0;
      }
      .built-with-footer .built-with-coin {
        font-size: 12px;
      }
    </style>
  </head>
  <body>
    <slot />

    {/* Open-source attribution. See comment in BaseLayout.astro frontmatter to remove. */}
    <footer class="built-with-footer" role="contentinfo">
      <span class="built-with-coin" aria-hidden="true">💸</span>
      <span>Built with</span>
      <a href={REPO_URL} target="_blank" rel="noopener noreferrer">
        <svg viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
          <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8Z"/>
        </svg>
        pay-me-back
      </a>
      <span>— make your own</span>
    </footer>
  </body>
</html>
