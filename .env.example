# .env.example — copy to .env and fill in for local dev.
# Real production values live in the Cloudflare Pages dashboard.
# DO NOT commit a real .env file.

# ────────────────────────────────────────────────────────────────────────────
# Build-time secrets (read by scripts/prebuild-debtors.mjs + injected into HTML)
# ────────────────────────────────────────────────────────────────────────────

# JSON-string of the debtor array.
# Locally you can leave this empty and edit data/debtors.json directly.
# In CI (Cloudflare Pages) this is required.
# Shape per debtor:
#   {"token":"abc...","name":"Alice","amount":50,"backstory":"...","characterSlug":"placeholder","createdAt":"2026-01-01T00:00:00Z"}
PAYLEO_DEBTORS_JSON=

# Admin token guarding /admin/<token>/. Generate via: npm run gen-debtor -- --admin
PAYLEO_ADMIN_TOKEN=

# PayPal handle (no @ prefix, no URL). Example: "yourpaypalhandle"
PAYLEO_PAYPAL_HANDLE=

# Bank details (used at build to render IBAN block + SEPA QR)
PAYLEO_BANK_HOLDER=
PAYLEO_BANK_IBAN=
PAYLEO_BANK_BIC=

# ────────────────────────────────────────────────────────────────────────────
# Optional extra payment methods (all opt-in — leave blank to hide the card).
# Each one renders a small card in the "Other ways to pay" section.
# ────────────────────────────────────────────────────────────────────────────

# Stripe Payment Link (https://buy.stripe.com/...). If the link's price is set
# to "Customer enters amount", ?prefilled_amount=<cents>&currency=eur autofills.
PAYLEO_STRIPE_LINK=

# Revolut.me handle (no URL). Example: "yourhandle" → revolut.me/yourhandle/50EUR
PAYLEO_REVOLUT_HANDLE=

# Wise handle (no URL). Example: "yourname" → wise.com/pay/me/yourname
PAYLEO_WISE_HANDLE=

# bunq.me handle. Example: "yourname" → bunq.me/yourname/50
PAYLEO_BUNQ_HANDLE=

# Bizum (Spain) — phone number to receive Bizum payments. Example: "+34 600123456"
PAYLEO_BIZUM_PHONE=

# Twint (Switzerland) — phone number tied to your Twint account.
PAYLEO_TWINT_PHONE=

# Swish (Sweden) — Swish number.
PAYLEO_SWISH_NUMBER=

# MB WAY (Portugal) — phone number.
PAYLEO_MBWAY_PHONE=

# Bitcoin address (P2WPKH/P2TR/etc. — anything BIP-21 compatible)
PAYLEO_BTC_ADDRESS=

# Ethereum address (0x...)
PAYLEO_ETH_ADDRESS=

# Ko-fi handle. Example: "yourname" → ko-fi.com/yourname
PAYLEO_KOFI_HANDLE=

# Buy Me a Coffee handle. Example: "yourname" → buymeacoffee.com/yourname
PAYLEO_BUYMEACOFFEE_HANDLE=

# ────────────────────────────────────────────────────────────────────────────
# Browser-exposed config (Astro inlines anything prefixed PUBLIC_*)
# ────────────────────────────────────────────────────────────────────────────

# Client-side API base URL.
#   Local dev:  http://localhost:8787 (wrangler dev)
#   Production: https://pay.your-domain.com   (set in .env.production, committed)
# If unset in prod the client falls back to same-origin.
PUBLIC_API_BASE=http://localhost:8787

# Render a loud yellow striped "DEMO PAGE — nothing here is real" banner at
# the top of every page. Set to "true" for showcase / demo deployments where
# the IBAN + payment methods point at fake values. Leave unset for production.
PAYLEO_DEMO_MODE=
